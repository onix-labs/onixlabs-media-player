{
  "name": "onixlabs-media-player",
  "version": "2026.0.0",
  "description": "Cross-platform media player with real-time audio visualizations, video playback, and MIDI synthesis",
  "author": {
    "name": "ONIXLabs",
    "email": "info@onixlabs.io"
  },
  "main": "src/electron/dist/main.js",
  "type": "module",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test && vitest run --config vitest.electron.config.ts",
    "build:ci": "npm run lint && npm run build && npm run build:electron && npm run test:angular && npm run test:electron:coverage",
    "test:angular": "ng test",
    "test:electron": "vitest run --config vitest.electron.config.ts",
    "test:electron:coverage": "vitest run --config vitest.electron.config.ts --coverage",
    "test:electron:watch": "vitest --config vitest.electron.config.ts",
    "lint": "eslint src/angular src/electron --ext .ts",
    "dev": "npm run lint && npm run build:preload && concurrently -k \"ng serve\" \"wait-on http://localhost:4200 && NODE_ENV=development DEV_SERVER_URL=http://localhost:4200 NODE_OPTIONS='--import tsx' electron src/electron/main.ts\"",
    "build:electron": "tsx scripts/build-electron.ts",
    "build:electron:dev": "tsc -p src/electron/tsconfig.prod.json",
    "build:preload": "esbuild src/electron/preload.ts --bundle --platform=node --format=esm --outfile=src/electron/dist/preload.js --external:electron",
    "build:all": "npm run lint && npm run build && npm run build:electron",
    "obfuscate": "tsx scripts/obfuscate.ts",
    "package": "npm run build:all && npm run obfuscate && electron-builder",
    "package:mac": "npm run build:all && npm run obfuscate && electron-builder --mac",
    "package:win": "npm run build:all && npm run obfuscate && electron-builder --win",
    "package:linux": "npm run build:all && npm run obfuscate && electron-builder --linux"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "private": true,
  "packageManager": "npm@11.6.2",
  "dependencies": {
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/router": "^21.0.0",
    "@fortawesome/fontawesome-free": "^7.1.0",
    "electron-log": "^5.4.3",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.0.4",
    "@angular/cli": "^21.0.4",
    "@angular/compiler-cli": "^21.0.0",
    "@types/node": "^25.0.8",
    "@typescript-eslint/eslint-plugin": "^8.53.0",
    "@typescript-eslint/parser": "^8.53.0",
    "@vitest/coverage-v8": "^4.0.18",
    "concurrently": "^9.2.1",
    "electron": "^39.2.7",
    "electron-builder": "^26.4.0",
    "esbuild": "^0.27.2",
    "eslint": "^9.39.2",
    "javascript-obfuscator": "^5.1.0",
    "jsdom": "^27.1.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8",
    "wait-on": "^9.0.3"
  },
  "build": {
    "appId": "com.onixlabs.media-player",
    "productName": "ONIXPlayer",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "src/electron/dist/**/*",
      "public/icon-macos.png",
      "public/icon-windows-linux.png",
      "node_modules/electron-log/**/*"
    ],
    "mac": {
      "category": "public.app-category.entertainment",
      "icon": "public/icon-macos.png",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "public/icon-windows-linux.png",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "icon": "public/icon-windows-linux.png",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "AudioVideo"
    },
    "fileAssociations": [
      {"ext": "mp3", "name": "MP3 Audio", "role": "Viewer"},
      {"ext": "flac", "name": "FLAC Audio", "role": "Viewer"},
      {"ext": "wav", "name": "WAV Audio", "role": "Viewer"},
      {"ext": "ogg", "name": "OGG Audio", "role": "Viewer"},
      {"ext": "m4a", "name": "M4A Audio", "role": "Viewer"},
      {"ext": "aac", "name": "AAC Audio", "role": "Viewer"},
      {"ext": "wma", "name": "WMA Audio", "role": "Viewer"},
      {"ext": "mp4", "name": "MP4 Video", "role": "Viewer"},
      {"ext": "m4v", "name": "M4V Video", "role": "Viewer"},
      {"ext": "mkv", "name": "MKV Video", "role": "Viewer"},
      {"ext": "avi", "name": "AVI Video", "role": "Viewer"},
      {"ext": "webm", "name": "WebM Video", "role": "Viewer"},
      {"ext": "mov", "name": "MOV Video", "role": "Viewer"},
      {"ext": "mid", "name": "MIDI File", "role": "Viewer"},
      {"ext": "midi", "name": "MIDI File", "role": "Viewer"},
      {"ext": "opp", "name": "ONIXPlayer Playlist", "role": "Editor"}
    ]
  }
}
